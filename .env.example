# Copy to .env for local development. Never commit .env.
FLASK_APP=wsgi.py
FLASK_DEBUG=1
SECRET_KEY=

# PostgreSQL runtime configuration
POSTGRES_DB=admission
POSTGRES_USER=admission
POSTGRES_PASSWORD=
# URL-encode reserved characters in the password. Docker host must remain db.
# DATABASE_URL=postgresql+psycopg://admission:<password>@db:5432/admission
DATABASE_URL=

# Optional BYOK providers. Keep empty until the related phase is implemented.
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
