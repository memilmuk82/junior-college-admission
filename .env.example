# Copy to .env for local development. Never commit .env.
FLASK_APP=wsgi.py
FLASK_DEBUG=1
SECRET_KEY=

# PostgreSQL runtime configuration
POSTGRES_DB=admission
POSTGRES_USER=admission
POSTGRES_PASSWORD=
# URL-encode reserved characters in the password. Docker host must remain db.
# DATABASE_URL=postgresql+psycopg://admission:<password>@db:5432/admission
DATABASE_URL=
APP_ENV=development
# Production only: comma-separated public hostnames and exactly one trusted reverse proxy.
PUBLIC_BASE_URL=
TRUSTED_HOSTS=
TRUST_PROXY_HOPS=0

# Google OIDC is opt-in. Keep real client credentials only in ignored env files
# or deployment secrets; never commit them. The callback path is fixed by the app.
GOOGLE_OIDC_ENABLED=false
GOOGLE_OIDC_CLIENT_ID=
GOOGLE_OIDC_CLIENT_SECRET=
# Exact external callback, e.g. https://service.example.test/auth/google/callback.
GOOGLE_REDIRECT_URI=

# Account verification and password-reset email. Keep disabled until the SMTP
# override and external secret files are ready. Links always use PUBLIC_BASE_URL.
ACCOUNT_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USERNAME_FILE=
SMTP_PASSWORD_FILE=
SMTP_USE_STARTTLS=true
EMAIL_FROM_ADDRESS=
SMTP_TIMEOUT_SECONDS=10

# Optional public portfolio demo account. This password is intentionally public,
# uses synthetic in-memory consultation data, and cannot use uploads, AI, or admin pages.
DEMO_LOGIN_NAME=
DEMO_PUBLIC_PASSWORD=
# 운영 로그인에서 격리된 전체 기능 체험 환경으로 이동하는 같은-origin 경로.
DEMO_SANDBOX_ENTRY_URL=/demo/auth/login

# 아래 값은 docker-compose.demo.yml 전용이다. 운영 앱에는 활성화하지 않는다.
DEMO_SANDBOX_ENABLED=false
DEMO_SANDBOX_INSTANCE_ID=
DEMO_SANDBOX_PUBLIC_PASSWORD=
DEMO_SANDBOX_PUBLIC_PASSWORD_FILE=
DEMO_EMAIL_OUTBOX_ENABLED=false
DEMO_GOOGLE_STUB_ENABLED=false
DEMO_CRAWLER_FIXTURE_ENABLED=false
DEMO_PUBLIC_BASE_URL=https://admission.memilmuk82.com/demo
DEMO_TRUSTED_HOSTS=admission.memilmuk82.com
DEMO_HEALTHCHECK_HOST=admission.memilmuk82.com
DEMO_ORIGIN_PORT=8002
DEMO_SECRETS_DIR=
# Production secret-file inputs. Do not set both a direct value and its _FILE form.
GOOGLE_OIDC_CLIENT_ID_FILE=
GOOGLE_OIDC_CLIENT_SECRET_FILE=
# Production Compose non-secret settings. Secret files remain under an ignored directory.
PRODUCTION_SECRETS_DIR=
# Host-readable paths used only by production-preflight; values stay in the files.
SECRET_KEY_FILE=
DATABASE_URL_FILE=
ADMIN_USERNAME_FILE=
ADMIN_PASSWORD_HASH_FILE=
BYOK_MASTER_KEY_FILE=
PRODUCTION_PUBLIC_BASE_URL=
PRODUCTION_TRUSTED_HOSTS=
PRODUCTION_HEALTHCHECK_HOST=
PRODUCTION_HTTP_PORT=80
PRODUCTION_HTTPS_PORT=443
PRODUCTION_ORIGIN_PORT=8000
PRODUCTION_PROXY_UID=
PRODUCTION_PROXY_GID=
PRODUCTION_POSTGRES_DB=admission
PRODUCTION_POSTGRES_USER=admission
PRODUCTION_WEB_WORKERS=2
PRODUCTION_WEB_THREADS=2

# Phase 9 credential-encryption master key. This is not a provider API key.
# Generate a Fernet key in the deployment secret manager and never commit its value.
BYOK_MASTER_KEY=

# Internal alpha profile. Copy this file to ignored .env.alpha and replace placeholders.
ALPHA_SECRET_KEY=
ALPHA_POSTGRES_DB=admission_alpha
ALPHA_POSTGRES_USER=admission_alpha
ALPHA_POSTGRES_PASSWORD=
# Container hostname must remain db-alpha. URL-encode reserved password characters.
ALPHA_DATABASE_URL=postgresql+psycopg://admission_alpha:<password>@db-alpha:5432/admission_alpha
ALPHA_ADMIN_USERNAME=
# In .env.alpha, single-quote this value so Compose preserves the hash's $ characters.
ALPHA_ADMIN_PASSWORD_HASH=
ALPHA_BYOK_MASTER_KEY=
ALPHA_GOOGLE_OIDC_ENABLED=false
ALPHA_GOOGLE_OIDC_CLIENT_ID=
ALPHA_GOOGLE_OIDC_CLIENT_SECRET=
ALPHA_GOOGLE_REDIRECT_URI=
ALPHA_DEMO_LOGIN_NAME=
ALPHA_DEMO_PUBLIC_PASSWORD=
ALPHA_WEB_PORT=5001

# Internal beta profile. Keep actual values only in ignored .env.beta or a secret manager.
BETA_SECRET_KEY=
BETA_POSTGRES_DB=admission_beta
BETA_POSTGRES_USER=admission_beta
BETA_POSTGRES_PASSWORD=
# Container hostname must remain db-beta. URL-encode reserved password characters.
BETA_DATABASE_URL=postgresql+psycopg://admission_beta:<password>@db-beta:5432/admission_beta
BETA_ADMIN_USERNAME=
# In .env.beta, single-quote this value so Compose preserves the hash's $ characters.
BETA_ADMIN_PASSWORD_HASH=
BETA_BYOK_MASTER_KEY=
BETA_GOOGLE_OIDC_ENABLED=false
BETA_GOOGLE_OIDC_CLIENT_ID=
BETA_GOOGLE_OIDC_CLIENT_SECRET=
BETA_GOOGLE_REDIRECT_URI=
BETA_DEMO_LOGIN_NAME=
BETA_DEMO_PUBLIC_PASSWORD=
BETA_WEB_PORT=5002
BETA_WEB_WORKERS=2
BETA_WEB_THREADS=2
