# Copy to .env for local development. Never commit .env.
FLASK_APP=wsgi.py
FLASK_DEBUG=1
SECRET_KEY=

# PostgreSQL runtime configuration
POSTGRES_DB=admission
POSTGRES_USER=admission
POSTGRES_PASSWORD=
# URL-encode reserved characters in the password. Docker host must remain db.
# DATABASE_URL=postgresql+psycopg://admission:<password>@db:5432/admission
DATABASE_URL=
APP_ENV=development
# Production only: comma-separated public hostnames and exactly one trusted reverse proxy.
PUBLIC_BASE_URL=
TRUSTED_HOSTS=
TRUST_PROXY_HOPS=0
# Production Compose non-secret settings. Secret files remain under an ignored directory.
PRODUCTION_SECRETS_DIR=
# Host-readable paths used only by production-preflight; values stay in the files.
SECRET_KEY_FILE=
DATABASE_URL_FILE=
ADMIN_USERNAME_FILE=
ADMIN_PASSWORD_HASH_FILE=
BYOK_MASTER_KEY_FILE=
PRODUCTION_PUBLIC_BASE_URL=
PRODUCTION_TRUSTED_HOSTS=
PRODUCTION_HEALTHCHECK_HOST=
PRODUCTION_HTTP_PORT=80
PRODUCTION_HTTPS_PORT=443
PRODUCTION_PROXY_UID=
PRODUCTION_PROXY_GID=
PRODUCTION_POSTGRES_DB=admission
PRODUCTION_POSTGRES_USER=admission
PRODUCTION_WEB_WORKERS=2
PRODUCTION_WEB_THREADS=2

# Phase 9 credential-encryption master key. This is not a provider API key.
# Generate a Fernet key in the deployment secret manager and never commit its value.
BYOK_MASTER_KEY=

# Internal alpha profile. Copy this file to ignored .env.alpha and replace placeholders.
ALPHA_SECRET_KEY=
ALPHA_POSTGRES_DB=admission_alpha
ALPHA_POSTGRES_USER=admission_alpha
ALPHA_POSTGRES_PASSWORD=
# Container hostname must remain db-alpha. URL-encode reserved password characters.
ALPHA_DATABASE_URL=postgresql+psycopg://admission_alpha:<password>@db-alpha:5432/admission_alpha
ALPHA_ADMIN_USERNAME=
# In .env.alpha, single-quote this value so Compose preserves the hash's $ characters.
ALPHA_ADMIN_PASSWORD_HASH=
ALPHA_BYOK_MASTER_KEY=
ALPHA_WEB_PORT=5001

# Internal beta profile. Keep actual values only in ignored .env.beta or a secret manager.
BETA_SECRET_KEY=
BETA_POSTGRES_DB=admission_beta
BETA_POSTGRES_USER=admission_beta
BETA_POSTGRES_PASSWORD=
# Container hostname must remain db-beta. URL-encode reserved password characters.
BETA_DATABASE_URL=postgresql+psycopg://admission_beta:<password>@db-beta:5432/admission_beta
BETA_ADMIN_USERNAME=
# In .env.beta, single-quote this value so Compose preserves the hash's $ characters.
BETA_ADMIN_PASSWORD_HASH=
BETA_BYOK_MASTER_KEY=
BETA_WEB_PORT=5002
BETA_WEB_WORKERS=2
BETA_WEB_THREADS=2
