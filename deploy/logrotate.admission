/var/log/nginx/admission.access.log /var/log/nginx/admission.error.log /var/log/nginx/admission.callback.error.log /var/log/nginx/admission.account-token.error.log /var/log/nginx/admission.demo-account-token.error.log {
    daily
    rotate 14
    maxsize 10M
    missingok
    compress
    delaycompress
    notifempty
    create 0640 www-data adm
    sharedscripts
    postrotate
        if [ -f /run/nginx.pid ]; then
            kill -USR1 "$(cat /run/nginx.pid)"
        fi
    endscript
}
